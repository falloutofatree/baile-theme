{% doc %}
  @prompt
    Create a hero section based on the current Hero included in this theme with an SVG border that consists of: 1. corner SVG (sits in each corner, non-repeating), 2. horizontal border (extends across the top and bottom between the corners) and 3. vertical border (extends across the left and right sides between the corners.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-border-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-hero-border__container-{{ ai_gen_id }} {
    position: relative;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    min-height: {{ block.settings.min_height }}px;
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    justify-content: {{ block.settings.horizontal_alignment }};
  }

  .ai-hero-border__content-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    text-align: {{ block.settings.text_alignment }};
    z-index: 2;
    position: relative;
  }

  .ai-hero-border__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
  }

  .ai-hero-border__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px;
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-hero-border__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-hero-border__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 32px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    transition: all 0.3s ease;
  }

  .ai-hero-border__button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_text }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.primary_button_border }};
  }

  .ai-hero-border__button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_bg }};
    color: {{ block.settings.primary_button_hover_text }};
  }

  .ai-hero-border__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_text }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.secondary_button_border }};
  }

  .ai-hero-border__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_bg }};
    color: {{ block.settings.secondary_button_hover_text }};
  }

  .ai-hero-border__svg-corner-{{ ai_gen_id }} {
    position: absolute;
    width: {{ block.settings.corner_size }}px;
    height: {{ block.settings.corner_size }}px;
    z-index: 1;
  }

  .ai-hero-border__svg-corner--top-left-{{ ai_gen_id }} {
    top: 0;
    left: 0;
  }

  .ai-hero-border__svg-corner--top-right-{{ ai_gen_id }} {
    top: 0;
    right: 0;
    transform: rotate(90deg);
  }

  .ai-hero-border__svg-corner--bottom-left-{{ ai_gen_id }} {
    bottom: 0;
    left: 0;
    transform: rotate(-90deg);
  }

  .ai-hero-border__svg-corner--bottom-right-{{ ai_gen_id }} {
    bottom: 0;
    right: 0;
    transform: rotate(180deg);
  }

  .ai-hero-border__svg-horizontal-{{ ai_gen_id }} {
    position: absolute;
    left: {{ block.settings.corner_size }}px;
    right: {{ block.settings.corner_size }}px;
    height: {{ block.settings.border_thickness }}px;
    z-index: 1;
  }

  .ai-hero-border__svg-horizontal--top-{{ ai_gen_id }} {
    top: 0;
  }

  .ai-hero-border__svg-horizontal--bottom-{{ ai_gen_id }} {
    bottom: 0;
  }

  .ai-hero-border__svg-vertical-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.corner_size }}px;
    bottom: {{ block.settings.corner_size }}px;
    width: {{ block.settings.border_thickness }}px;
    z-index: 1;
  }

  .ai-hero-border__svg-vertical--left-{{ ai_gen_id }} {
    left: 0;
  }

  .ai-hero-border__svg-vertical--right-{{ ai_gen_id }} {
    right: 0;
  }

  .ai-hero-border__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .ai-hero-border__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-border__container-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-hero-border__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-hero-border__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-hero-border__svg-corner-{{ ai_gen_id }} {
      width: {{ block.settings.corner_size_mobile }}px;
      height: {{ block.settings.corner_size_mobile }}px;
    }

    .ai-hero-border__svg-horizontal-{{ ai_gen_id }} {
      left: {{ block.settings.corner_size_mobile }}px;
      right: {{ block.settings.corner_size_mobile }}px;
      height: {{ block.settings.border_thickness_mobile }}px;
    }

    .ai-hero-border__svg-vertical-{{ ai_gen_id }} {
      top: {{ block.settings.corner_size_mobile }}px;
      bottom: {{ block.settings.corner_size_mobile }}px;
      width: {{ block.settings.border_thickness_mobile }}px;
    }

    .ai-hero-border__buttons-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-hero-border__button-{{ ai_gen_id }} {
      text-align: center;
    }
  }
{% endstyle %}

<div class="ai-hero-border-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-border__container-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-hero-border__image-{{ ai_gen_id }}"
      >
    {% endif %}

    {% if block.settings.show_overlay %}
      <div class="ai-hero-border__overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    <svg class="ai-hero-border__svg-corner-{{ ai_gen_id }} ai-hero-border__svg-corner--top-left-{{ ai_gen_id }}" viewBox="0 0 100 100" preserveAspectRatio="none">
      <path d="M0,0 L100,0 L100,20 Q100,0 80,0 L20,0 Q0,0 0,20 L0,100 L0,0 Z" fill="{{ block.settings.border_color }}" />
    </svg>

    <svg class="ai-hero-border__svg-corner-{{ ai_gen_id }} ai-hero-border__svg-corner--top-right-{{ ai_gen_id }}" viewBox="0 0 100 100" preserveAspectRatio="none">
      <path d="M0,0 L100,0 L100,20 Q100,0 80,0 L20,0 Q0,0 0,20 L0,100 L0,0 Z" fill="{{ block.settings.border_color }}" />
    </svg>

    <svg class="ai-hero-border__svg-corner-{{ ai_gen_id }} ai-hero-border__svg-corner--bottom-left-{{ ai_gen_id }}" viewBox="0 0 100 100" preserveAspectRatio="none">
      <path d="M0,0 L100,0 L100,20 Q100,0 80,0 L20,0 Q0,0 0,20 L0,100 L0,0 Z" fill="{{ block.settings.border_color }}" />
    </svg>

    <svg class="ai-hero-border__svg-corner-{{ ai_gen_id }} ai-hero-border__svg-corner--bottom-right-{{ ai_gen_id }}" viewBox="0 0 100 100" preserveAspectRatio="none">
      <path d="M0,0 L100,0 L100,20 Q100,0 80,0 L20,0 Q0,0 0,20 L0,100 L0,0 Z" fill="{{ block.settings.border_color }}" />
    </svg>

    <svg class="ai-hero-border__svg-horizontal-{{ ai_gen_id }} ai-hero-border__svg-horizontal--top-{{ ai_gen_id }}" preserveAspectRatio="none">
      <rect width="100%" height="100%" fill="{{ block.settings.border_color }}" />
    </svg>

    <svg class="ai-hero-border__svg-horizontal-{{ ai_gen_id }} ai-hero-border__svg-horizontal--bottom-{{ ai_gen_id }}" preserveAspectRatio="none">
      <rect width="100%" height="100%" fill="{{ block.settings.border_color }}" />
    </svg>

    <svg class="ai-hero-border__svg-vertical-{{ ai_gen_id }} ai-hero-border__svg-vertical--left-{{ ai_gen_id }}" preserveAspectRatio="none">
      <rect width="100%" height="100%" fill="{{ block.settings.border_color }}" />
    </svg>

    <svg class="ai-hero-border__svg-vertical-{{ ai_gen_id }} ai-hero-border__svg-vertical--right-{{ ai_gen_id }}" preserveAspectRatio="none">
      <rect width="100%" height="100%" fill="{{ block.settings.border_color }}" />
    </svg>

    <div class="ai-hero-border__content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-hero-border__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-hero-border__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}

      {% if block.settings.button_label_1 != blank or block.settings.button_label_2 != blank %}
        <div class="ai-hero-border__buttons-{{ ai_gen_id }}">
          {% if block.settings.button_label_1 != blank %}
            <a href="{{ block.settings.button_link_1 }}" class="ai-hero-border__button-{{ ai_gen_id }} ai-hero-border__button--primary-{{ ai_gen_id }}">
              {{ block.settings.button_label_1 }}
            </a>
          {% endif %}

          {% if block.settings.button_label_2 != blank %}
            <a href="{{ block.settings.button_link_2 }}" class="ai-hero-border__button-{{ ai_gen_id }} ai-hero-border__button--secondary-{{ ai_gen_id }}">
              {{ block.settings.button_label_2 }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

