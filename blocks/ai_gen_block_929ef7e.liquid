{% doc %}
  @prompt
    Act as a Shopify Liquid and CSS developer. Create a custom theme block for the Product page using a vertical Accordion layout.
    
    1. Content & Schema Structure:
    Create 6 rich text settings in the schema for these specific panels: "Details", "Materials", "Ingredients", "About the Maker", "Why We Love It", and "Shipping & Returns". Each setting MUST be configured with "dynamic_source": true to allow connection to product metafields.
    
    2. Logical Rendering:
    
    Conditional Visibility: For every panel, wrap the HTML in a Liquid {% if block.settings.[id] != blank %} tag. If the setting or the connected dynamic source is empty, do not render that panel in the DOM.
    
    Default State: Implement logic to ensure the first populated panel (the first one with content) is assigned an open or active class by default on page load.
    
    3. Theme-Consistent Styling:
    
    Typography: Style the panel titles to use the theme’s Accent font variable at exactly 16px.
    
    Color & Opacity: The text and toggle icons must be 100% opaque and inherit the parent section's primary text color using CSS variables like rgb(var(--color-foreground)).
    
    Background: Set the background to transparent or inherit to match the parent section perfectly.
    
    Dividers: Include a subtle horizontal divider (1px solid) between each panel using the theme's default border color variable (e.g., rgb(var(--color-border))).
    
    4. Interactivity:
    
    Use a lightweight vanilla JavaScript toggle. Opening one panel should automatically close any other open panels.
    
    Ensure the transition between open and closed states is smooth.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-accordion-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: transparent;
  }

  .ai-product-accordion__item-{{ ai_gen_id }} {
    border-bottom: 1px solid rgb(var(--color-border));
  }

  .ai-product-accordion__item-{{ ai_gen_id }}:first-child {
    border-top: 1px solid rgb(var(--color-border));
  }

  .ai-product-accordion__header-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  .ai-product-accordion__title-{{ ai_gen_id }} {
    font-family: var(--font-accent--family);
    font-size: 16px;
    font-weight: var(--font-accent--weight);
    color: rgb(var(--color-foreground));
    opacity: 1;
    margin: 0;
  }

  .ai-product-accordion__icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: rgb(var(--color-foreground));
    opacity: 1;
  }

  .ai-product-accordion__item-{{ ai_gen_id }}.active .ai-product-accordion__icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-product-accordion__content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-product-accordion__content-inner-{{ ai_gen_id }} {
    padding-bottom: 16px;
    color: rgb(var(--color-foreground));
    opacity: 1;
  }

  .ai-product-accordion__content-inner-{{ ai_gen_id }} p {
    margin: 0 0 12px 0;
  }

  .ai-product-accordion__content-inner-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }
{% endstyle %}

<product-accordion-{{ ai_gen_id }} class="ai-product-accordion-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% liquid
    assign panels = 'panel_details,panel_materials,panel_ingredients,panel_about_maker,panel_why_love,panel_shipping' | split: ','
    assign panel_titles = 'Details,Materials,Ingredients,About the Maker,Why We Love It,Shipping & Returns' | split: ','
    assign first_panel_found = false
  %}

  {% for panel in panels %}
    {% assign panel_content = block.settings[panel] %}
    {% if panel_content != blank %}
      {% assign panel_index = forloop.index0 %}
      {% assign panel_title = panel_titles[panel_index] %}
      {% assign is_first = false %}
      {% unless first_panel_found %}
        {% assign is_first = true %}
        {% assign first_panel_found = true %}
      {% endunless %}

      <div class="ai-product-accordion__item-{{ ai_gen_id }} {% if is_first %}active{% endif %}" data-accordion-item>
        <button class="ai-product-accordion__header-{{ ai_gen_id }}" aria-expanded="{% if is_first %}true{% else %}false{% endif %}">
          <span class="ai-product-accordion__title-{{ ai_gen_id }}">{{ panel_title }}</span>
          <svg class="ai-product-accordion__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="ai-product-accordion__content-{{ ai_gen_id }} rte">
          <div class="ai-product-accordion__content-inner-{{ ai_gen_id }}">
            {{ panel_content }}
          </div>
        </div>
      </div>
    {% endif %}
  {% endfor %}
</product-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('[data-accordion-item]');
        this.setupEventListeners();
        this.initializeFirstPanel();
      }

      initializeFirstPanel() {
        const firstActiveItem = this.querySelector('.ai-product-accordion__item-{{ ai_gen_id }}.active');
        if (firstActiveItem) {
          const content = firstActiveItem.querySelector('.ai-product-accordion__content-{{ ai_gen_id }}');
          const contentInner = firstActiveItem.querySelector('.ai-product-accordion__content-inner-{{ ai_gen_id }}');
          if (content && contentInner) {
            content.style.maxHeight = contentInner.scrollHeight + 'px';
          }
        }
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const header = item.querySelector('.ai-product-accordion__header-{{ ai_gen_id }}');
          const content = item.querySelector('.ai-product-accordion__content-{{ ai_gen_id }}');
          const contentInner = item.querySelector('.ai-product-accordion__content-inner-{{ ai_gen_id }}');

          header.addEventListener('click', () => {
            const isActive = item.classList.contains('active');

            this.items.forEach((otherItem) => {
              if (otherItem !== item) {
                otherItem.classList.remove('active');
                const otherContent = otherItem.querySelector('.ai-product-accordion__content-{{ ai_gen_id }}');
                const otherHeader = otherItem.querySelector('.ai-product-accordion__header-{{ ai_gen_id }}');
                otherContent.style.maxHeight = '0';
                otherHeader.setAttribute('aria-expanded', 'false');
              }
            });

            if (isActive) {
              item.classList.remove('active');
              content.style.maxHeight = '0';
              header.setAttribute('aria-expanded', 'false');
            } else {
              item.classList.add('active');
              content.style.maxHeight = contentInner.scrollHeight + 'px';
              header.setAttribute('aria-expanded', 'true');
            }
          });
        });
      }
    }

    customElements.define('product-accordion-{{ ai_gen_id }}', ProductAccordion{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product accordion",
  "tag": null,
  "settings": [
    {
      "type": "richtext",
      "id": "panel_details",
      "label": "Details"
    },
    {
      "type": "richtext",
      "id": "panel_materials",
      "label": "Materials"
    },
    {
      "type": "richtext",
      "id": "panel_ingredients",
      "label": "Ingredients"
    },
    {
      "type": "richtext",
      "id": "panel_about_maker",
      "label": "About the Maker"
    },
    {
      "type": "richtext",
      "id": "panel_why_love",
      "label": "Why We Love It"
    },
    {
      "type": "richtext",
      "id": "panel_shipping",
      "label": "Shipping & Returns"
    }
  ],
  "presets": [
    {
      "name": "Product accordion"
    }
  ]
}
{% endschema %}
