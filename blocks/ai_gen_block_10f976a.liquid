      "id": "card_1_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Card 2"
    },
    {
      "type": "image_picker",
      "id": "card_2_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "card_2_category",
      "label": "Category",
      "default": "Design"
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Title",
      "default": "Minimalist Spaces"
    },
    {
      "type": "textarea",
      "id": "card_2_excerpt",
      "label": "Excerpt",
      "default": "Creating calm through thoughtful design and intentional curation."
    },
    {
      "type": "url",
      "id": "card_2_link",
      "label": "Link"
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Card title size",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_excerpt_size",
      "label": "Card excerpt size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
