    },
    {
      "type": "range",
      "id": "hero_title_size",
      "label": "Title size",
      "min": 24,
      "max": 72,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "hero_excerpt_size",
      "label": "Excerpt size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Card 1"
    },
    {
      "type": "image_picker",
      "id": "card_1_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "card_1_category",
      "label": "Category",
      "default": "Lifestyle"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Title",
      "default": "Morning Rituals"
    },
    {
      "type": "textarea",
      "id": "card_1_excerpt",
      "label": "Excerpt",
      "default": "Simple practices to start your day with intention and clarity."
