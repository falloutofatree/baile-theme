

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

{%- comment -%} Mobile back link - shown above hero on small screens {%- endcomment -%}
<div class="blog-post-hero-back blog-post-hero-back--mobile">
  <a href="{{ blog.url }}" class="blog-post-back-link">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
    <span>Back to {{ blog.title }}</span>
  </a>
</div>

{%- comment -%} Blog post hero - full width 50/50 grid {%- endcomment -%}
<div class="blog-post-hero">
  {%- if article.image -%}
    <div class="blog-post-hero__media">
      {%- content_for 'block', id: 'blog-post-image', type: '_blog-post-featured-image' %}
    </div>
  {%- endif -%}

  <div class="blog-post-hero__content color-{{ section.settings.hero_color_scheme }}">
    <div class="blog-post-hero-back blog-post-hero-back--desktop">
      <a href="{{ blog.url }}" class="blog-post-back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
        <span>Back to {{ blog.title }}</span>
      </a>
    </div>
    <div class="blog-post-hero__content-bottom">
      {%- content_for 'block', id: 'blog-post-title', type: 'text' %}
      {%- content_for 'block', id: 'blog-post-details', type: '_blog-post-info-text' %}
    </div>
  </div>
</div>

{%- comment -%} Blog post body content {%- endcomment -%}
<div class="section color-{{ section.settings.color_scheme }}">
  <div
    class="
      spacing-style
      section-content-wrapper
      blog-post-layout
    "
    style="
      {% render 'spacing-style', settings: section.settings %}
    "
  >
    {%- content_for 'block', id: 'blog-post-content', type: '_blog-post-content' %}

    {% comment %} Dynamic area for @app blocks only, at the bottom {% endcomment %}
    {% content_for 'blocks' %}

    {% if blog.comments_enabled? %}
      <div class="blog-post-comments-container">
        <h2 class="h3">{{- 'blogs.article.comments_heading' | t: count: article.comments_count -}}</h2>

        <div class="blog-post-comments">
          {% paginate article.comments by 10 %}
            {% for comment in article.comments %}
              <div class="blog-post-comment">
                {{ comment.content }}
                <div class="blog-post-comment__author">
                  <span class="blog-post-comment__author-name">{{- comment.author -}}</span>
                  <span>{{- 'blogs.article.comment_author_separator' | t -}}</span>
                  <span class="blog-post-comment__date">
                    {{- comment.created_at | time_tag: format: 'date' -}}
                  </span>
                </div>
              </div>
            {% endfor %}

            <div class="blog-post-comments-pagination">
              {{- paginate | default_pagination -}}
            </div>
          {% endpaginate %}
        </div>

        {% render 'blog-comment-form', article: article, section_id: section.id %}
      </div>
    {% endif %}
  </div>
</div>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% stylesheet %}
  .blog-post-layout {
    display: flex;
    flex-direction: column;
    gap: var(--gap-3xl);
  }

  /* Mobile back link - above hero */
  .blog-post-hero-back--mobile {
    padding: var(--padding-sm) var(--page-margin);
  }

  .blog-post-hero-back--desktop {
    display: none;
  }

  .blog-post-back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size--body-sm);
    color: currentColor;
    text-decoration: none;
    opacity: 0.7;
    transition: opacity var(--animation-speed) var(--animation-easing);
  }

  .blog-post-back-link:hover {
    opacity: 1;
  }

  .blog-post-back-link svg {
    flex-shrink: 0;
  }

  /* Hero grid */
  .blog-post-hero {
    display: grid;
    grid-template-columns: 1fr;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .blog-post-hero-back--mobile {
      display: none;
    }

    .blog-post-hero-back--desktop {
      display: block;
    }

    .blog-post-hero {
      grid-template-columns: 1fr 1fr;
    }
  }

  .blog-post-hero__media {
    width: 100%;
    overflow: hidden;
  }

  .blog-post-hero__media .blog-post-featured-image {
    width: 100%;
    height: 100%;
  }

  .blog-post-hero__media .blog-post-featured-image__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-post-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--gap-xl) var(--page-margin);
  }

  @media screen and (min-width: 750px) {
    .blog-post-hero__content {
      position: relative;
      padding: var(--gap-xl);
    }

    .blog-post-hero-back--desktop {
      position: absolute;
      top: var(--gap-xl);
      left: var(--gap-xl);
    }
  }

  .blog-post-hero__content-bottom {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
  }

  .blog-post-comments-container {
    width: 100%;
    max-width: var(--normal-content-width);
    margin: 0 auto;
  }

  .blog-post-comments {
    display: flex;
    flex-direction: column;
    gap: var(--gap-3xl);
  }

  .blog-post-comment__author {
    display: flex;
    align-items: center;
    gap: var(--gap-2xs);
    margin-top: var(--margin-md);
    font-size: var(--font-size--body-sm);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .blog-post-comments-pagination {
    display: flex;
    justify-content: center;
    gap: var(--gap-2xs);
  }

  .blog-post-comments-pagination,
  .blog-post-comments-pagination a {
    color: var(--color-foreground);
  }

  .blog-post-comments-pagination .current {
    color: var(--color-foreground);
  }

  .blog-post-comments-pagination .current,
  .blog-post-comments-pagination a {
    display: block;
    padding: var(--padding-2xs) var(--padding-xs);
  }

  .blog-post-comments-pagination .current,
  .blog-post-comments-pagination a:hover {
    border-bottom: 1px solid var(--color-foreground);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.blog_post",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "class": "section-wrapper",
  "settings": [
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        }
      ],
      "default": "column",
      "visible_if": "{{ section.settings.gap < 0 }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "hero_color_scheme",
      "label": "Hero color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": []
}
{% endschema %}
